<?php

/**
 * @file
 * Runtime helpers for Emerging Digital strategic content.
 */

declare(strict_types=1);

use Drupal\node\NodeInterface;

/**
 * Implements hook_metatags_alter().
 */
function emerging_digital_content_metatags_alter(array &$metatags, array &$context): void {
  $entity = $context['entity'] ?? NULL;
  if (!_emerging_digital_content_is_agence_drupal_belgique_page($entity)) {
    return;
  }

  $description = _emerging_digital_content_agence_drupal_belgique_meta_description();
  $title = _emerging_digital_content_agence_drupal_belgique_seo_title();

  $metatags['title'] = $title;
  $metatags['description'] = $description;
  $metatags['og_title'] = $title;
  $metatags['og_description'] = $description;
  $metatags['twitter_cards_title'] = $title;
  $metatags['twitter_cards_description'] = $description;
  $metatags['schema_web_page_description'] = $description;
  $metatags['schema_web_page_name'] = 'Agence Drupal en Belgique';
  $metatags['schema_web_page_type'] = 'FAQPage';
}

/**
 * Implements hook_page_attachments().
 */
function emerging_digital_content_page_attachments(array &$attachments): void {
  $node = \Drupal::routeMatch()->getParameter('node');
  if (!_emerging_digital_content_is_agence_drupal_belgique_page($node)) {
    return;
  }

  $schema = [
    '@context' => 'https://schema.org',
    '@type' => 'FAQPage',
    'mainEntity' => _emerging_digital_content_agence_drupal_belgique_faq_schema(),
  ];

  $attachments['#attached']['html_head'][] = [
    [
      '#type' => 'html_tag',
      '#tag' => 'script',
      '#value' => json_encode($schema, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
      '#attributes' => [
        'type' => 'application/ld+json',
      ],
    ],
    'emerging_digital_agence_drupal_belgique_faq_schema',
  ];
}

/**
 * Returns whether the entity is the Agence Drupal Belgique landing page.
 */
function _emerging_digital_content_is_agence_drupal_belgique_page(mixed $entity): bool {
  return $entity instanceof NodeInterface
    && $entity->uuid() === _emerging_digital_content_agence_drupal_belgique_uuid();
}

/**
 * Returns the landing page default content UUID.
 */
function _emerging_digital_content_agence_drupal_belgique_uuid(): string {
  return '0b4b1728-7c80-4c17-a057-ebf52dc4eb5a';
}

/**
 * Returns the SEO title for the landing page.
 */
function _emerging_digital_content_agence_drupal_belgique_seo_title(): string {
  return 'Agence Drupal en Belgique | Sites Drupal, IA, SEO technique';
}

/**
 * Returns the meta description for the landing page.
 */
function _emerging_digital_content_agence_drupal_belgique_meta_description(): string {
  return 'Emerging Digital accompagne PME, ASBL et institutions en Belgique dans la création, la refonte, la migration et l’optimisation de sites Drupal rapides, accessibles et enrichis par l’IA.';
}

/**
 * Returns FAQPage schema entries for the landing page.
 */
function _emerging_digital_content_agence_drupal_belgique_faq_schema(): array {
  $answers = [
    'Pourquoi choisir Drupal pour une PME ou une ASBL ?' => 'Drupal convient aux organisations qui veulent un site durable, sécurisé et évolutif, avec des rôles éditoriaux clairs, des contenus structurés et une base technique capable de grandir sans repartir de zéro.',
    'Travaillez-vous uniquement avec Drupal ?' => 'Drupal reste l’expertise principale d’Emerging Digital. Les compétences PHP, Symfony et Laravel renforcent l’architecture, les intégrations et la maintenance de projets complexes.',
    'Pouvez-vous reprendre un site Drupal existant ?' => 'Oui. Emerging Digital peut auditer un site Drupal existant, corriger ses priorités techniques, préparer une migration, améliorer ses performances et stabiliser son workflow éditorial.',
    'Comment intégrez-vous l’IA dans Drupal ?' => 'L’IA est intégrée par des usages concrets : aide à la rédaction, optimisation SEO, traduction, préparation de variantes de contenu et assistance aux équipes éditoriales.',
    'Intervenez-vous à Bruxelles et en Wallonie ?' => 'Oui. Emerging Digital accompagne des PME, ASBL et institutions en Belgique, notamment à Bruxelles, en Wallonie et à distance.',
    'Drupal est-il adapté au SEO ?' => 'Oui. Drupal permet de structurer les contenus, contrôler les métadonnées, optimiser les performances, gérer les redirections et produire des pages accessibles et lisibles par les moteurs comme par les assistants IA.',
    'Drupal est-il mieux que WordPress ?' => 'Drupal n’est pas toujours le bon choix pour un petit site très simple. Il devient pertinent quand le projet demande une architecture éditoriale solide, de la sécurité, des rôles avancés, des intégrations ou une durée de vie longue.',
  ];

  $schema = [];
  foreach ($answers as $question => $answer) {
    $schema[] = [
      '@type' => 'Question',
      'name' => $question,
      'acceptedAnswer' => [
        '@type' => 'Answer',
        'text' => $answer,
      ],
    ];
  }

  return $schema;
}
