/**
 * Converts a content path into a rendered URL for the active language.
 */
function emerging_digital_service_url(string $path, LanguageInterface $language): string {
  return Url::fromUserInput($path, ['language' => $language])->toString();
}

/**
 * Classifies a service card into the Services hub families.
 *
 * @param array<string, string> $card
 *   Parsed card data.
 */
function emerging_digital_service_card_group(array $card): string {
  $haystack = strtolower(sprintf(
    '%s %s',
    $card['title'] ?? '',
    $card['url'] ?? '',
  ));

  $ai_markers = [
    'ia-pour-pme',
    'ai-for-smes',
    'ia-drupal',
    'ai-drupal',
    'automatisation',
    'automation',
    'documentaire',
    'document',
    'workflow',
    'chatbot',
  ];
  foreach ($ai_markers as $marker) {
    if (str_contains($haystack, $marker)) {
      return 'ai';
    }
  }

  $drupal_markers = [
    'drupal',
    'accessibilite-seo-optimisation',
    'accessibility-seo',
    'ia-integree',
    'integrated-ai',
  ];
  foreach ($drupal_markers as $marker) {
    if (str_contains($haystack, $marker)) {
      return 'drupal';
    }
  }

  $business_markers = [
    'agence-web',
    'web-agency',
    'creation-site-web-professionnel',
    'professional-website-creation',
    'refonte-site-internet',
    'website-redesign',
    'site-web-pme',
    'sme-website',
  ];
  foreach ($business_markers as $marker) {
    if (str_contains($haystack, $marker)) {
      return 'business';
    }
  }

  return 'other';
}

/**
 * Implements hook_preprocess_paragraph__ai_features().
 */
function emerging_digital_preprocess_paragraph__ai_features(array &$variables): void {
  $paragraph = $variables['paragraph'] ?? NULL;
  if (!$paragraph || !$paragraph->hasField('field_items')) {
    return;
  }

  $language = $paragraph->language();
  $langcode = $language->getId();
  $variables['ai_feature_cards'] = [];

  foreach ($paragraph->get('field_items') as $item) {
    $parts = array_map('trim', explode('|', (string) $item->value));
    $url = '';

    if (!empty($parts[2])) {
      try {
        $url = Url::fromUserInput($parts[2], ['language' => $language])->toString();
      }
      catch (\InvalidArgumentException) {
        $url = $parts[2];
      }
    }

    $variables['ai_feature_cards'][] = [
      'title' => $parts[0] ?? '',
      'description' => $parts[1] ?? '',
      'url' => $url,
      'cta_label' => $langcode === 'en' ? 'Explore' : 'Explorer',
    ];
  }
}

/**
 * Implements hook_preprocess_paragraph__hero().
 */
function emerging_digital_preprocess_paragraph__hero(array &$variables): void {
  $is_front = !empty($variables['is_front']);
  $variables['heading_tag'] = $is_front ? 'h1' : 'h2';
  $illustration = emerging_digital_hero_illustration($is_front);
  $variables['hero_illustration_class'] = 'ed-section--hero-' . $illustration['variant'];
  $variables['hero_illustration_src'] = $illustration['src'];
  $variables['hero_illustration_alt'] = $illustration['alt'];
  $variables['hero_illustration_loading'] = !empty($variables['is_front']) ? 'eager' : 'lazy';

  if (isset($variables['content']['field_hero_media'][0])) {
    $variables['hero_media'] = $variables['content']['field_hero_media'];
    unset($variables['content']['field_hero_media']);
  }
}

/**
 * Selects the business illustration for a hero paragraph.
 *
 * Media-rendered illustrations are handled first in Twig when a project field
 * exists. The theme SVG map keeps Content Sync pages deterministic and provides
 * the mandatory fallback when no media is available.
 *
 * @return array{variant: string, src: string, alt: string}
 *   Selected hero illustration metadata.
 */
function emerging_digital_hero_illustration(bool $is_front = FALSE): array {
  $variant = 'home';
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();
  if (!$is_front) {
    $current_path = \Drupal::service('path.current')->getPath();
    $alias = \Drupal::service('path_alias.manager')
      ->getAliasByPath($current_path, $langcode);
    $node = \Drupal::routeMatch()->getParameter('node');

    if ($alias === $current_path && $node instanceof NodeInterface) {
      if ($node->hasField('path') && !$node->get('path')->isEmpty()) {
        $alias = (string) ($node->get('path')->alias ?? '');
      }
    }

    $variant_by_alias = [
      '/accueil' => 'home',
      '/home' => 'home',
      '/ia-drupal' => 'ia-drupal',
      '/ai-drupal' => 'ia-drupal',
      '/services' => 'services',
      '/contact' => 'contact',
      '/cas-clients' => 'case-clients',
      '/case-studies' => 'case-clients',
      '/equipe' => 'team',
      '/team' => 'team',
    ];
    $variant = $variant_by_alias[$alias] ?? $variant;
  }

  $theme_path = \Drupal::service('extension.list.theme')->getPath('emerging_digital');
  $definitions = emerging_digital_hero_illustration_definitions();
  $definition = $definitions[$variant] ?? $definitions['home'];

  return [
    'variant' => $variant,
    'src' => base_path() . $theme_path . '/' . $definition['path'],
    'alt' => $definition['alt'][$langcode] ?? $definition['alt']['fr'],
  ];
}

