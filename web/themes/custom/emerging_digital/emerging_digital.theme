        'eyebrow' => 'Premium Drupal foundation',
        'title' => 'Drupal expertise',
        'description' => 'For structured, multilingual and durable platforms '
        . 'where content governance, security and maintainability matter.',
        'cta_label' => 'Discuss a Drupal project',
        'cta_url' => emerging_digital_service_url('/en/contact', $language),
        'cards' => [],
      ],
      'business' => [
        'key' => 'business',
        'eyebrow' => 'Business journeys',
        'title' => 'Web solutions for SMEs',
        'description' => 'For creation, redesign and visibility needs that '
        . 'must stay clear for non-technical teams and credible for '
        . 'decision makers.',
        'cta_label' => 'Structure your website',
        'cta_url' => emerging_digital_service_url('/en/contact', $language),
        'cards' => [],
      ],
      'ai' => [
        'key' => 'ai',
        'eyebrow' => 'Governed AI',
        'title' => 'AI and automation',
        'description' => 'Useful AI use cases, documented workflows and human '
        . 'validation, without turning the website into an uncontrolled '
        . 'black box.',
        'cta_label' => 'Frame an AI use case',
        'cta_url' => emerging_digital_service_url('/en/contact', $language),
        'cards' => [],
      ],
      'other' => [
        'key' => 'other',
        'eyebrow' => 'Related expertise',
        'title' => 'Other services',
        'description' => '',
        'cta_label' => 'Get in touch',
        'cta_url' => emerging_digital_service_url('/en/contact', $language),
        'cards' => [],
      ],
    ];
  }

  return [
    'drupal' => [
      'key' => 'drupal',
      'eyebrow' => 'Socle Drupal premium',
      'title' => 'Expertises Drupal',
      'description' => 'Pour les plateformes structurées, multilingues et '
      . 'durables, où la gouvernance de contenu, la sécurité et la '
      . 'maintenabilité comptent.',
      'cta_label' => 'Parler d’un projet Drupal',
      'cta_url' => emerging_digital_service_url('/fr/contact', $language),
      'cards' => [],
    ],
    'business' => [
      'key' => 'business',
      'eyebrow' => 'Parcours business',
      'title' => 'Solutions web pour PME',
      'description' => 'Pour les besoins de création, de refonte et de '
      . 'visibilité qui doivent rester lisibles pour les équipes et '
      . 'crédibles pour les décideurs.',
      'cta_label' => 'Structurer votre site web',
      'cta_url' => emerging_digital_service_url('/fr/contact', $language),
      'cards' => [],
    ],
    'ai' => [
      'key' => 'ai',
      'eyebrow' => 'IA encadrée',
      'title' => 'IA et automatisation',
      'description' => 'Des usages IA utiles, des workflows documentés et une '
      . 'validation humaine, sans transformer le site en boîte noire '
      . 'incontrôlée.',
      'cta_label' => 'Cadrer un usage IA',
      'cta_url' => emerging_digital_service_url('/fr/contact', $language),
      'cards' => [],
    ],
    'other' => [
      'key' => 'other',
      'eyebrow' => 'Expertises liées',
      'title' => 'Autres services',
      'description' => '',
      'cta_label' => 'Prendre contact',
      'cta_url' => emerging_digital_service_url('/fr/contact', $language),
