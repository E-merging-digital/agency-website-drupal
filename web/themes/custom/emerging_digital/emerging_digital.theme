<?php

/**
 * @file
 * Theme hooks and preprocess functions for the Emerging Digital theme.
 */

declare(strict_types=1);

use Drupal\Core\Language\LanguageInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\webform\Entity\Webform;

/**
 * Implements hook_preprocess_node().
 */
function emerging_digital_preprocess_node(array &$variables): void {
  $node = $variables['node'] ?? NULL;
  if (!$node) {
    return;
  }

  $bundle = $node->bundle();
  $is_english = $node->language()->getId() === 'en';
  $variables['contact_qualification_cta'] = emerging_digital_contact_qualification_cta(
    $bundle,
    $node->label(),
    $is_english,
  );

  if ($bundle !== 'ai_feature') {
    return;
  }

  $variables['ai_feature_summary_label'] = $is_english
    ? 'AI feature summary'
    : 'Synthèse de la fonctionnalité IA';
  $variables['ai_feature_benefit_label'] = $is_english
    ? 'Customer benefit'
    : 'Bénéfice client';
  $variables['ai_feature_example_label'] = $is_english
    ? 'Concrete example'
    : 'Exemple concret';
  $variables['ai_feature_use_cases_label'] = $is_english
    ? 'Use cases'
    : 'Cas d’usage';
  $variables['ai_feature_related_services_label'] = $is_english
    ? 'Related services'
    : 'Services liés';
}

/**
 * Implements hook_preprocess_form().
 */
function emerging_digital_preprocess_form(array &$variables): void {
  $form_id = (string) ($variables['element']['#form_id'] ?? '');
  $is_admin_route = \Drupal::service('router.admin_context')->isAdminRoute();

  if ($form_id === '' || $is_admin_route) {
    return;
  }

  $system_form_ids = [
    'user_login_form' => 'login',
    'user_pass' => 'password-reset',
    'user_register_form' => 'register',
    'search_form' => 'search',
    'search_block_form' => 'search-block',
  ];

  if (!isset($system_form_ids[$form_id])) {
    return;
  }

  $variant = $system_form_ids[$form_id];
  $variables['element']['#attributes']['class'][] = 'ed-system-form';
  $variables['element']['#attributes']['class'][] = 'ed-system-form--' . $variant;
}

/**
 * Builds a localized contact qualification CTA for detail pages.
 *
 * @return array<string, string>
 *   CTA metadata for Twig templates, or an empty array when unsupported.
 */
function emerging_digital_contact_qualification_cta(
  string $bundle,
  string $title,
  bool $is_english,
): array {
  $definitions = [
    'service' => [
      'type' => emerging_digital_contact_qualification_type($title),
      'source' => 'service',
      'label' => $is_english
        ? 'Qualify this service need'
        : 'Qualifier ce besoin service',
      'title' => $is_english
        ? 'Ready to frame this service?'
        : 'Prêt à cadrer ce service ?',
      'text' => $is_english
        ? 'Continue to the contact form with this service context already prepared.'
        : 'Poursuivez vers le formulaire avec ce contexte service déjà préparé.',
    ],
    'ai_feature' => [
      'type' => 'ai',
      'source' => 'ai_feature',
      'label' => $is_english
        ? 'Frame this AI use case'
        : 'Cadrer cet usage IA',
      'title' => $is_english
        ? 'Need to qualify this AI use case?'
        : 'Besoin de qualifier cet usage IA ?',
      'text' => $is_english
        ? 'Share this AI context through the contact form without adding automation or chatbot steps.'
        : 'Transmettez ce contexte IA via le formulaire, sans automatisation ni chatbot.',
    ],
    'case_client' => [
      'type' => emerging_digital_contact_qualification_type($title),
      'source' => 'case_client',
      'label' => $is_english
        ? 'Discuss a similar project'
        : 'Parler d’un projet similaire',
      'title' => $is_english
        ? 'Want to discuss a similar path?'
        : 'Envie d’échanger sur un parcours similaire ?',
      'text' => $is_english
        ? 'Use the contact form with this case-study context to make the first exchange more useful.'
        : 'Utilisez le formulaire avec ce contexte de cas client pour rendre le premier échange plus utile.',
    ],
  ];

  if (!isset($definitions[$bundle])) {
    return [];
  }

  $definition = $definitions[$bundle];
  $path = $is_english ? '/en/contact' : '/fr/contact';
  $query = http_build_query([
    'type' => $definition['type'],
    'source' => $definition['source'],
    'context' => $title,
  ]);

  return [
    'label' => $definition['label'],
    'title' => $definition['title'],
    'text' => $definition['text'],
    'url' => $path . '?' . $query . '#contact-form',
  ];
}

/**
 * Infers the qualification type from a page title.
 */
function emerging_digital_contact_qualification_type(string $title): string {
  $normalized = strtolower($title);
  $markers = [
    'audit' => ['audit'],
    'redesign' => ['refonte', 'redesign'],
    'migration' => ['migration'],
    'maintenance' => ['maintenance', 'support'],
    'ai' => ['ia', 'ai'],
  ];

  foreach ($markers as $type => $needles) {
    foreach ($needles as $needle) {
      if (str_contains($normalized, $needle)) {
        return $type;
      }
    }
  }

  return 'redesign';
}

/**
 * Implements hook_preprocess_paragraph().
 */
function emerging_digital_preprocess_paragraph(array &$variables): void {
  $paragraph = $variables['paragraph'] ?? NULL;
  if (!$paragraph) {
    return;
  }

  $bundle = $paragraph->bundle();

  if (isset($variables['content']['field_link'][0])) {
    $variables['content']['field_link'][0]['#options']['attributes']['class'][] = 'button';
    $variables['content']['field_link'][0]['#options']['attributes']['class'][] = 'button--primary';
  }

  if ($bundle === 'hero' && isset($variables['content']['field_secondary_link'][0])) {
    $variables['content']['field_secondary_link'][0]['#options']['attributes']['class'][] = 'button';
    $variables['content']['field_secondary_link'][0]['#options']['attributes']['class'][] = 'button--secondary';
  }

  if ($bundle === 'text_block' && $paragraph->uuid() === '855b08da-0ec9-4261-883a-d27f214606e6') {
    $contact_webform = Webform::load('contact');
    if ($contact_webform) {
      $variables['contact_webform'] = \Drupal::entityTypeManager()
        ->getViewBuilder('webform')
        ->view($contact_webform);
    }
  }
}

/**
 * Implements hook_preprocess_paragraph__services().
 */
function emerging_digital_preprocess_paragraph__services(array &$variables): void {
  $paragraph = $variables['paragraph'] ?? NULL;
  if (!$paragraph || !$paragraph->hasField('field_items')) {
    return;
  }

  $language = $paragraph->language();
  $langcode = $language->getId();
  $service_groups = emerging_digital_service_group_definitions($langcode, $language);
  $variables['service_cards'] = [];

  foreach ($paragraph->get('field_items') as $item) {
    $parts = array_map('trim', explode('|', (string) $item->value));
    $url = '';

    if (!empty($parts[2])) {
      try {
        $url = Url::fromUserInput($parts[2], ['language' => $language])->toString();
      }
      catch (\InvalidArgumentException) {
        $url = $parts[2];
      }
    }

    $card = [
      'title' => $parts[0] ?? '',
      'description' => $parts[1] ?? '',
      'url' => $url,
      'cta_label' => $langcode === 'en' ? 'Discover' : 'Découvrir',
    ];

    $group_key = $parts[3] ?? emerging_digital_service_card_group($card);
    if (!isset($service_groups[$group_key])) {
      $group_key = 'other';
    }

    $service_groups[$group_key]['cards'][] = $card;
    $variables['service_cards'][] = $card;
  }

  $variables['service_groups'] = array_values(array_filter(
    $service_groups,
    static fn (array $group): bool => !empty($group['cards']),
  ));
}

