<section{{ attributes.addClass('ed-section', 'ed-section--ai-features-grid') }}>
  <div class="ed-container">
    <h2 class="ed-section__title">{{ paragraph.field_heading.value }}</h2>
    {% if paragraph.field_text.value %}
      <div class="ed-section__intro">{{ content.field_text }}</div>
    {% endif %}
    <div class="ed-cards ed-cards--ai">
      {% for item in paragraph.field_items %}
        <article class="ed-card ed-card--ai">
          <h3>{{ item.value|striptags|trim }}</h3>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
