<section{{ attributes.addClass('component', 'component--ai-features') }}>
  <div class="component__inner">
    {% if content.field_heading %}
      <h2 class="component__title">{{ content.field_heading }}</h2>
    {% endif %}
    {% if content.field_text %}
      <div class="component__text">{{ content.field_text }}</div>
    {% endif %}
    <div class="cards-grid" aria-label="Fonctionnalités IA">
      <article class="card card--ai">
        <h3>Copilote éditorial</h3>
        <p>Accélère la production des pages Services et des contenus experts.</p>
      </article>
      <article class="card card--ai">
        <h3>Qualification intelligente</h3>
        <p>Pré-qualifie les leads pour réduire les délais de réponse commerciale.</p>
      </article>
      <article class="card card--ai">
        <h3>Insights conversion</h3>
        <p>Priorise les actions à impact business direct avec des signaux lisibles.</p>
      </article>
    </div>
  </div>
</section>
