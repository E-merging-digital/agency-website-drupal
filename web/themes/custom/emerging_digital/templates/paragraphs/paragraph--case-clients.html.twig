<section{{ attributes.addClass('ed-section', 'ed-section--case-studies') }}>
  <div class="ed-container">
    <h2 class="ed-section__title">{{ paragraph.field_heading.value }}</h2>
    {% if paragraph.field_text.value %}
      <div class="ed-section__intro">{{ content.field_text }}</div>
    {% endif %}
    <div class="ed-cards ed-cards--cases">
      {% for item in paragraph.field_items %}
        {% set idx = loop.index0 %}
        <article class="ed-card ed-card--case">
          <h3>{{ item.value|striptags|trim }}</h3>
          <p><strong>Problème :</strong> {{ paragraph.field_case_problem[idx].value|striptags|trim }}</p>
          <p><strong>Solution :</strong> {{ paragraph.field_case_solution[idx].value|striptags|trim }}</p>
          <p><strong>Résultat :</strong> {{ paragraph.field_case_result[idx].value|striptags|trim }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
