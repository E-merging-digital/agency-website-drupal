<section{{ attributes.addClass('component', 'component--hero') }}>
  <div class="component__inner">
    <p class="component__eyebrow">Agence Drupal orientée conversion</p>
    {% if content.field_heading %}
      <h2 class="component__title component__title--hero">{{ content.field_heading }}</h2>
    {% endif %}
    {% if content.field_text %}
      <div class="component__text component__text--lead">{{ content.field_text }}</div>
    {% endif %}
    {% if content.field_link %}
      <div class="component__actions component__actions--inline">{{ content.field_link }}</div>
    {% endif %}
  </div>
</section>
